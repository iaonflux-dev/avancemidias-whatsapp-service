# Supabase project (mesmo do Lovable Cloud)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...   # service_role key (NUNCA exponha no frontend)

# Workspace que este gateway atende (UUID da tabela workspaces)
WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# Porta do servidor Express (saúde + reconectar)
PORT=3333

# Pasta onde a sessão do Baileys será persistida em disco
AUTH_DIR=./auth

# Edge Function que processa cada mensagem recebida
CHAT_AGENT_URL=https://YOUR-PROJECT.supabase.co/functions/v1/chat-agent